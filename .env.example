# Domaj Configuration
# Copy this file to .env and adjust values

# Server Configuration
SERVER_PORT=3000
WEB_PORT=8080

# Scan interval (cron expression - 6 fields: sec min hour day month weekday)
# Default: daily at midnight
SCAN_INTERVAL=0 0 0 * * *

# API Secret for agent authentication
# IMPORTANT: Change this in production!
API_SECRET=change-me-in-production

# SMTP Configuration for email notifications
# Leave empty to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Notification recipients (comma-separated)
NOTIFY_EMAILS=

# Logging level
RUST_LOG=domaj_server=info,tower_http=info
