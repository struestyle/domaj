DATABASE_URL=sqlite:/data/domaj.db?mode=rwc
PORT=3000
SCAN_INTERVAL=0 0 0 * * *
API_SECRET=change-me-in-production
JWT_SECRET=jwt-secret-change-me-in-production-32chars

# Admin account (optional, created on startup if not exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# SMTP Configuration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_EMAILS=

RUST_LOG=domaj_server=info,tower_http=debug

# Private Registry Credentials (optional)
# Supports up to 10 registries (REGISTRY_1_*, REGISTRY_2_*, ...)
REGISTRY_1_HOST=
REGISTRY_1_USER=
REGISTRY_1_PASSWORD=
