DATABASE_URL=sqlite:/data/domaj.db?mode=rwc
PORT=3000
SCAN_INTERVAL=${SCAN_INTERVAL:-0 0 * * *}
API_SECRET=${API_SECRET:-change-me-in-production}
SMTP_HOST=${SMTP_HOST:-}
SMTP_PORT=${SMTP_PORT:-587}
SMTP_USER=${SMTP_USER:-}
SMTP_PASSWORD=${SMTP_PASSWORD:-}
SMTP_FROM=${SMTP_FROM:-}
NOTIFY_EMAILS=${NOTIFY_EMAILS:-}
RUST_LOG=${RUST_LOG:-domaj_server=info,tower_http=debug}
